# ============================================================
# ComicTeach marketing site — environment variables
# ============================================================
#
# The marketing site itself has NO secrets. It's a static
# Next.js app served from Vercel. The variables below are only
# used at *build* time to inject the right URLs into pages and
# OG images.
#
# Copy this file to `.env.local` and edit before deploying.
# ============================================================

# Public site URL. Used for canonical tags, OG images, sitemap.
NEXT_PUBLIC_SITE_URL=https://comicteach.com

# (Optional) Plausible / PostHog analytics — leave blank to disable.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_POSTHOG_KEY=
